{
    "name": "Cal Poly ECE4203 2026",
    "image": "dvanblerkom/ece4203:2026",
    "hostRequirements": {
        "cpus": 4,
        "memory": "8gb",
        "storage": "32gb"
    },
    "forwardPorts": [6080],
    "portsAttributes": {
        "6080": {
            "label": "Desktop",
            "onAutoForward": "openBrowser"
        }
    },
    "postStartCommand": "bash /workspaces/ece4203/scripts/start-vnc.sh"
    "remoteUser": "user",
    "customizations": {
        "vscode": {
            "extensions": [
                "mshr-h.veriloghdl",
                "leafvmaple.verilog-formatter"
            ]
        },
        "codespaces": {
            "idleTimeoutMinutes": 15
        }
    }
}
